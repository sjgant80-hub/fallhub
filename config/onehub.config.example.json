  "ai": {
    "provider": "webllm",
    "provider_options": ["webllm", "anthropic", "openai"],
    "voice_hint": "Warm, brief (2-3 sentences), always moves toward booking or clear next step. Never invents information.",
    "auto_draft": true,
    "auto_send": false,
    "temperature": 0.6
  },

  "operator": {
    "name": "Jane Sample",
    "email": "jane@samplestay.co.uk",
    "voice_persona": "9 years hosting · direct · gently witty · never salesy",
    "checkin_time": "16:00",
    "checkout_time": "10:00",
    "quiet_hours": "22:00-08:00",
    "instant_book": true,
    "review_response_target_hours": 24
  },

  "policies": {
    "cancellation": "Full refund if cancelled 30+ days before arrival. 50% if 14-29 days. Non-refundable within 14 days.",
    "damage_deposit_gbp": 100,
    "children": true,
    "dogs": true,
    "smoking": false,
    "parties": false
  },

  "legal": {
    "business_registered_name": "SampleStay Ltd",
    "companies_house_number": "12345678",
    "vat_number": null,
    "terms_url": "/terms.html",
    "privacy_url": "/privacy.html",
