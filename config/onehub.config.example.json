    "airbnb": {
      "enabled": true,
      "ical_import_per_unit": {
        "cabin-a": "https://www.airbnb.com/calendar/ical/12345678.ics?s=SECRET",
        "cabin-b": "https://www.airbnb.com/calendar/ical/12345679.ics?s=SECRET",
        "cabin-c": "https://www.airbnb.com/calendar/ical/12345680.ics?s=SECRET"
      },
      "typical_commission_pct": 15
    },
    "booking_com": {
      "enabled": true,
      "ical_import_per_unit": {
        "cabin-a": "https://admin.booking.com/hotel/gb/ical/9876543.ics?t=TOKEN",
        "cabin-b": "https://admin.booking.com/hotel/gb/ical/9876544.ics?t=TOKEN"
      },
      "typical_commission_pct": 18
    },
    "agoda": {
      "enabled": false,
      "ical_import_per_unit": {}
    },
    "whatsapp": {
      "enabled": true,
      "provider": "twilio",
      "sender_number": "+441234567890"
    },
    "email": {
      "enabled": true,
      "provider": "resend",
      "from_address": "bookings@samplestay.co.uk",
      "reply_to": "bookings@samplestay.co.uk"
    },
    "sms": {
      "enabled": false,
      "provider": "twilio",
