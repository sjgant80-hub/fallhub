    "location": {
      "address": "Sample Lane, Canterbury, Kent",
      "postcode": "CT1 1AA",
      "country_code": "GB",
      "lat": 51.31,
      "lng": 1.10,
      "timezone": "Europe/London"
    },
    "contact": {
